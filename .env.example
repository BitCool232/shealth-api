# Anthropic Claude API key
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Optional: Vercel KV for persistent caching (upgrade from in-memory)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional: Rate limit config
# RATE_LIMIT_FREE_TIER=20
# RATE_LIMIT_PRO_TIER=100
